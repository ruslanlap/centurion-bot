# Required
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
ADMIN_ID=123456789

# Optional: bot name (without @)
BOT_NAME="centurion_bot"

# Optional: database URL (defaults to local SQLite)
# For SQLite (default):
# DATABASE_URL="sqlite+aiosqlite:///data/centurion.db"
# For MySQL:
# DATABASE_URL="mysql+asyncmy://user:password@localhost:3306/centurion"

# Optional: log level
LOG_LEVEL="INFO"

# Optional: webhook mode (leave empty for polling)
# WEBHOOK_URL="https://your-domain.com/webhook"
# WEBHOOK_HOST="0.0.0.0"
# WEBHOOK_PORT=8080
# WEBHOOK_SECRET="random-secret-string"
